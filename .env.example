# ---- CheckVisaSlots ----
# Your CheckVisaSlots access code / API key.
# Get it: open the "Check US Visa Slots" extension popup -> the "Access Code"
# (API key) field. Or from your account at https://checkvisaslots.com
CVS_API_KEY=

# The extension version the API expects. Bump if CheckVisaSlots updates it.
EXT_VERSION=4.7.3

# ---- Notifications ----
# Which provider to use: ntfy | whatsapp | both
NOTIFY_PROVIDER=ntfy

# ntfy (push) — install the ntfy app, subscribe to a hard-to-guess topic name.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=   # only needed for a private/self-hosted ntfy server

# WhatsApp via CallMeBot (optional). Number in international format, e.g. +14085551234
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# ---- Behaviour (all optional) ----
# How often to poll, in seconds. 120 = every 2 minutes.
POLL_INTERVAL_SECONDS=120

# Only alert on sightings seen within this many minutes (freshness window).
MAX_AGE_MINUTES=20

# Don't re-alert the same location more often than this (unless it changes).
NOTIFY_COOLDOWN_MINUTES=15

# Optional: comma-separated location filter (substring match, case-insensitive).
# Leave blank for all relevant locations. Example: NEW DELHI,CHENNAI,HYDERABAD
LOCATIONS=
